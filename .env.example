# ─── PostgreSQL ───────────────────────────────────────────────
BOT_DATABASE_URL=postgresql://user:pass@localhost:5432/edge_protocol

# ─── D&B API ───────────────────────────────────────────────────
DEBUNK_API_URL=
DEBUNK_API_KEY=your_secret_api_key

# ─── Webhook ────────────────────────────────────────────────────
# Use localhost if the bot is on the same VPS, otherwise use external domain
BOT_WEBHOOK_URL=
BOT_PORT=3000

# ─── Trading parameters ─────────────────────────────────────────
TARGET_PROFIT_MULT=1.05   # +5% from entry_price
DISCOVERY_INTERVAL_MINUTES=5   # How often to scan Gamma API for markets
MIN_LIQUIDITY_USDC=1000   # Minimum market liquidity filter

# ─── Google Sheets (reporting) ──────────────────────────────────
GOOGLE_SHEET_ID=your_sheet_id
GOOGLE_SERVICE_ACCOUNT_KEY=path_to_json_or_base64_string
GOOGLE_SHEET_NAME=Sheet1
