  "description": "Edge Trader Bot — autonomous virtual trading on Polymarket via Gamma, D&B, and CLOB APIs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
